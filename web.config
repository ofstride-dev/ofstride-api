<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <add name="PythonHandler" path="*" verb="*" modules="httpPlatformHandler" resourceType="Unspecified" />
    </handlers>
    <httpPlatform processPath="python" arguments="-m uvicorn api.app:app --host 0.0.0.0 --port %HTTP_PLATFORM_PORT%">
      <environmentVariables>
        <environmentVariable name="PYTHONPATH" value="%APP_PATH%" />
      </environmentVariables>
    </httpPlatform>
  </system.webServer>
</configuration>
